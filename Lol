-- GUN PATCH
-- ═══════════════════════════════════════════
local gunOriginals = {}
local function patchGun()
    local ok, Items = pcall(function() return require(ReplicatedStorage.Modules.ItemLibrary).Items end)
    if not ok or not Items then return end
    local ex = {Sniper=true,Crossbow=true,Bow=true,RPG=true}
    for name, data in pairs(Items) do
        if typeof(data)~="table" or ex[name] then continue end
        if not gunOriginals[name] then
            gunOriginals[name] = {ShootSpread=data.ShootSpread,ShootAccuracy=data.ShootAccuracy,ShootRecoil=data.ShootRecoil,ShootCooldown=data.ShootCooldown,ShootBurstCooldown=data.ShootBurstCooldown}
        end
        if GunCFG.NoSpread then
            if data.ShootSpread   then data.ShootSpread   = 0 end
            if data.ShootAccuracy then data.ShootAccuracy = 0 end
        else
            if data.ShootSpread   then data.ShootSpread   = gunOriginals[name].ShootSpread   end
            if data.ShootAccuracy then data.ShootAccuracy = gunOriginals[name].ShootAccuracy end
        end
        if GunCFG.NoRecoil then
            if data.ShootRecoil then data.ShootRecoil = 0 end
        else
            if data.ShootRecoil then data.ShootRecoil = gunOriginals[name].ShootRecoil end
        end
        if GunCFG.FastShoot then
            if data.ShootCooldown      then data.ShootCooldown      = 0.05 end
            if data.ShootBurstCooldown then data.ShootBurstCooldown = 0.05 end
        else
            if data.ShootCooldown      then data.ShootCooldown      = gunOriginals[name].ShootCooldown      end
            if data.ShootBurstCooldown then data.ShootBurstCooldown = gunOriginals[name].ShootBurstCooldown end
        end
    end
end

