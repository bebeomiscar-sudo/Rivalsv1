local function getHRP(p) local c=p.Character return c and c:FindFirstChild("HumanoidRootPart") end
local function getHum(p) local c=p.Character return c and c:FindFirstChildOfClass("Humanoid") end

local function isVisible(from, target)
    local rp=RaycastParams.new()
    rp.FilterDescendantsInstances={LP.Character}
    rp.FilterType=Enum.RaycastFilterType.Exclude
    local res=workspace:Raycast(from,(target-from),rp)
    return not res or res.Instance:IsDescendantOf(target.Parent)
end

local function isSameTeam(p)
    return pcall(function() return LP.Team and p.Team and LP.Team==p.Team end) and LP.Team==p.Team
end

-- ГўвЂўВђГўвЂўВђ TARGET SELECTION ГўвЂўВђГўвЂўВђ
-- Finds closest player by world distance (not screen - works looking any direction)
local function getClosest(opts)
    opts = opts or {}
    local teamCheck = opts.teamCheck or false
    local visCheck  = opts.visCheck  or false
    local radius    = opts.radius    or math.huge
    local closest, closestD = nil, math.huge
    local localHRP = getHRP(LP)
    if not localHRP then return nil end
    for _,p in pairs(Players:GetPlayers()) do
        if p==LP then continue end
        if teamCheck and isSameTeam(p) then continue end
        local hrp=getHRP(p) if not hrp then continue end
        local hum=getHum(p) if not hum or hum.Health<=0 then continue end
        local d=(hrp.Position-localHRP.Position).Magnitude
        if d>radius then continue end
        if visCheck and not isVisible(Camera.CFrame.Position, hrp.Position) then continue end
        if d<closestD then closestD=d closest=p end
    end
    return closest
end

-- ГўвЂўВђГўвЂўВђ SILENT AIM ГўвЂўВђГўвЂўВђ
local currentTarget=nil

local function applyMemorySA()
    -- Hook utility raycast to redirect shot to target
    if not _util or not _origRaycast then return end
    _util.Raycast=function(...)
        local args={...}
        if katanaActive and #args>0 then
            args[3]=Vector3.new(args[3].X+math.random(10,30),args[3].Y+math.random(10,30),args[3].Z+math.random(10,30))
            return _origRaycast(table.unpack(args))
        end
        if not S.SilentAim.Enabled then return _origRaycast(table.unpack(args)) end
        local roll=math.random(1,100)
        if roll<=S.SilentAim.HitChance then
            local t=getClosest({teamCheck=S.SilentAim.TeamCheck,visCheck=S.SilentAim.VisibleOnly})
            if t and t.Character then
                local part=t.Character:FindFirstChild(S.SilentAim.HitPart) or t.Character:FindFirstChild("UpperTorso") or t.Character:FindFirstChild("HumanoidRootPart")
                if part and args[3] then
                    currentTarget=t
                    args[3]=part.Position
                    if S.Misc.HitSound.Enabled then task.spawn(playSound,S.Misc.HitSound.Sound) end
                end
            end
        end
        return _origRaycast(table.unpack(args))
    end
end

local function removeMemorySA()
    if _util and _origRaycast then _util.Raycast=_origRaycast currentTarget=nil end
end

-- Mouse SA: physically move the mouse to target before shooting
local function applyMouseSA()
    -- Hook InputBegan to redirect mouse position on M1 press
    RS.RenderStepped:Connect(function()
        if not S.SilentAim.Enabled or S.SilentAim.Mode~="Mouse" then return end
        if not isShooting then return end
        local t=getClosest({teamCheck=S.SilentAim.TeamCheck,visCheck=S.SilentAim.VisibleOnly})
        if not t or not t.Character then return end
        local part=t.Character:FindFirstChild(S.SilentAim.HitPart) or t.Character:FindFirstChild("HumanoidRootPart")
        if not part then return end
        local sp,on=Camera:WorldToViewportPoint(part.Position)
        if on and sp.Z>0 then
            pcall(function() mousemoveabs(sp.X,sp.Y) end)
        end
    end)
end

-- Camera SA: rotate camera to face target before shooting
local function applyCameraSA()
    RS.RenderStepped:Connect(function()
        if not S.SilentAim.Enabled or S.SilentAim.Mode~="Camera" then return end
        if not isShooting then return end
        local t=getClosest({teamCheck=S.SilentAim.TeamCheck,visCheck=S.SilentAim.VisibleOnly})
        if not t or not t.Character then return end
        local part=t.Character:FindFirstChild(S.SilentAim.HitPart) or t.Character:FindFirstChild("HumanoidRootPart")
        if not part then return end
        local dir=(part.Position-Camera.CFrame.Position).Unit
        Camera.CFrame=CFrame.new(Camera.CFrame.Position,Camera.CFrame.Position+dir)
    end)
end

-- Start all SA modes (hooks run once, Mode flag controls behavior each frame)
local saStarted=false
local function startSilentAim()
    if saStarted then return end saStarted=true
    applyMemorySA()
    applyMouseSA()
    applyCameraSA()
end
local function stopSilentAim()
    S.SilentAim.Enabled=false
    removeMemorySA()
end

-- ГўвЂўВђГўвЂўВђ AIMBOT ГўвЂўВђГўвЂўВђ
-- Memory mode: snap CFrame, Mouse mode: move mouse, Camera mode: rotate camera
local aimbotConn=nil
local function startAimbot()
    if aimbotConn then aimbotConn:Disconnect() end
    aimbotConn=RS.RenderStepped:Connect(function(dt)
        if not S.Aimbot.Enabled then aimbotConn:Disconnect() aimbotConn=nil return end
        if S.Aimbot.UseKeybind and not UIS:IsKeyDown(S.Aimbot.Keybind) then return end
        local t=getClosest({teamCheck=S.Aimbot.TeamCheck,visCheck=S.Aimbot.VisibleOnly,radius=S.Aimbot.Radius})
        if not t or not t.Character then return end
        local part=t.Character:FindFirstChild(S.Aimbot.HitPart) or t.Character:FindFirstChild("HumanoidRootPart")
        if not part then return end
        local mode=S.Aimbot.Mode
        if mode=="Camera" then
            local dir=(part.Position-Camera.CFrame.Position).Unit
            local goal=CFrame.new(Camera.CFrame.Position,Camera.CFrame.Position+dir)
            Camera.CFrame=Camera.CFrame:Lerp(goal,S.Aimbot.Smoothness)
        elseif mode=="Mouse" then
            local sp,on=Camera:WorldToViewportPoint(part.Position)
            if on and sp.Z>0 then
                local vp=Camera.ViewportSize
                local cx,cy=vp.X/2,vp.Y/2
                local tx,ty=sp.X,sp.Y
                local nx=cx+(tx-cx)*S.Aimbot.Smoothness
                local ny=cy+(ty-cy)*S.Aimbot.Smoothness
                pcall(function() mousemoveabs(nx,ny) end)
            end
        elseif mode=="Memory" then
            -- Direct camera lerp (same as Camera but instant for memory mode)
            local dir=(part.Position-Camera.CFrame.Position).Unit
            local goal=CFrame.new(Camera.CFrame.Position,Camera.CFrame.Position+dir)
            Camera.CFrame=Camera.CFrame:Lerp(goal,math.clamp(S.Aimbot.Smoothness*2,0.01,1))
        end
    end)
end
local function stopAimbot()
    S.Aimbot.Enabled=false
    if aimbotConn then aimbotConn:Disconnect() aimbotConn=nil end
end

-- ГўвЂўВђГўвЂўВђ TRIGGERBOT ГўвЂўВђГўвЂўВђ
local trigConn=nil
local lastTrigFire=0
local function trigShoot()
    pcall(function()
        if mouse1press then mouse1press() task.wait(0.01) mouse1release()
        elseif mouse1click then mouse1click() end
    end)
end
local function startTriggerbot()
    if trigConn then trigConn:Disconnect() end
    trigConn=RS.Heartbeat:Connect(function()
        if not S.Triggerbot.Enabled then trigConn:Disconnect() trigConn=nil return end
        local vp=Camera.ViewportSize
        local ray=Camera:ScreenPointToRay(vp.X/2,vp.Y/2)
        local rp=RaycastParams.new()
        rp.FilterDescendantsInstances={LP.Character}
        rp.FilterType=Enum.RaycastFilterType.Exclude
        local res=workspace:Raycast(ray.Origin,ray.Direction*2000,rp)
        if not res then return end
        local hitModel=res.Instance:FindFirstAncestorOfClass("Model")
        for _,p in pairs(Players:GetPlayers()) do
            if p~=LP and p.Character==hitModel then
                if S.Triggerbot.TeamCheck and isSameTeam(p) then return end
                local hum=getHum(p) if not hum or hum.Health<=0 then return end
                local now=tick()
                if now-lastTrigFire<S.Triggerbot.Delay then return end
                lastTrigFire=now
                task.delay(S.Triggerbot.Delay,trigShoot)
            end
        end
    end)
end
local function stopTriggerbot()
    S.Triggerbot.Enabled=false
    if trigConn then trigConn:Disconnect() trigConn=nil end
end

-- ГўвЂўВђГўвЂўВђ RAPID FIRE ГўвЂўВђГўвЂўВђ
local rfConn=nil
local function startRF()
    S.Guns.AttackCooldown=true
    if rfConn then rfConn:Disconnect() end
    rfConn=RS.Heartbeat:Connect(function()
        if not S.Guns.AttackCooldown then rfConn:Disconnect() rfConn=nil return end
        pcall(function()
            local rs=_cr(game:GetService("ReplicatedStorage"))
            local itemsModule=rs:FindFirstChild("Items",true)
            if not itemsModule then return end
            local Items=require(itemsModule)
            local exceptions={Knife=true,Fists=true,Katana=true,Chainsaw=true,Scythe=true,["Battle Axe"]=true,Maul=true}
            for name,data in pairs(Items) do
                if typeof(data)=="table" and not exceptions[name] then
                    if data.ShootSpread        then data.ShootSpread=0 end
                    if data.ShootAccuracy      then data.ShootAccuracy=0 end
                    if data.ShootRecoil        then data.ShootRecoil=0 end
                    if data.ShootCooldown      then data.ShootCooldown=0.05 end
                    if data.ShootBurstCooldown then data.ShootBurstCooldown=0.05 end
                end
            end
        end)
    end)
end
local function stopRF()
    S.Guns.AttackCooldown=false
    if rfConn then rfConn:Disconnect() rfConn=nil end
end

