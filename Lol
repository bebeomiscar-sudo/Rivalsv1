local function getChamTargets()
    local arms, weapons = {}, {}
    pcall(function()
        local vmRoot = workspace:FindFirstChild("ViewModels")
        if not vmRoot then return end
        local fp = vmRoot:FindFirstChild("FirstPerson"); if not fp then return end
        for _, model in ipairs(fp:GetChildren()) do
            if model.Name:find(LP.Name, 1, true) then
                for _, v in ipairs(model:GetDescendants()) do
                    if v:IsA("BasePart") or v:IsA("MeshPart") then
                        local n = v.Name:lower()
                        local pn = v.Parent and v.Parent.Name:lower() or ""
                        if pn:find("arm") or pn:find("hand") or n:find("arm") or n:find("hand") or pn=="armature" then
                            table.insert(arms, v)
                        end
                    end
                end
                local iv = model:FindFirstChild("ItemVisual")
                if iv then
                    for _, v in ipairs(iv:GetDescendants()) do
                        if v:IsA("BasePart") or v:IsA("MeshPart") then
                            table.insert(weapons, v)
                        end
                    end
                end
            end
        end
    end)
    return arms, weapons
end

local function applyChams()
    local arms, weapons = getChamTargets()
    if ChamCFG.ArmOn then
        for _, p in ipairs(arms) do
            pcall(function() p.Color=ChamCFG.ArmColor; p.Transparency=ChamCFG.ArmTransparency end)
        end
    end
    if ChamCFG.WeaponOn then
        for _, p in ipairs(weapons) do
            pcall(function() p.Color=ChamCFG.WeaponColor; p.Transparency=ChamCFG.WeaponTransparency end)
        end
    end
end

