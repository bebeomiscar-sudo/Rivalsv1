local TracerGui=Instance.new("ScreenGui") TracerGui.Name="LogicTracers" TracerGui.ResetOnSpawn=false TracerGui.IgnoreGuiInset=true TracerGui.ZIndexBehavior=Enum.ZIndexBehavior.Sibling TracerGui.Parent=LP.PlayerGui
local activeTracers={} local tracerHue=0
local function getOrigin() local vp=Camera.ViewportSize local o=S.Misc.BulletTracer.Origin if o=="Top" then return Vector2.new(vp.X/2,0) elseif o=="Middle" then return Vector2.new(vp.X/2,vp.Y/2) end return Vector2.new(vp.X/2,vp.Y) end
local function fireTracer()
    if not S.Misc.BulletTracer.Enabled then return end
    local char=LP.Character if not char then return end
    local rp=RaycastParams.new() rp.FilterDescendantsInstances={char} rp.FilterType=Enum.RaycastFilterType.Exclude
    local res=workspace:Raycast(Camera.CFrame.Position,Camera.CFrame.LookVector*2000,rp)
    local hitPos=res and res.Position or (Camera.CFrame.Position+Camera.CFrame.LookVector*1000)
    local hsp,hon=Camera:WorldToViewportPoint(hitPos) if not hon or hsp.Z<0 then return end
    local sFrom=getOrigin() local sTo=Vector2.new(hsp.X,hsp.Y) local delta=sTo-sFrom local length=delta.Magnitude if length<2 then return end
    local col=S.Misc.BulletTracer.Rainbow and Color3.fromHSV(tracerHue,1,1) or S.Misc.BulletTracer.Color
    if S.Misc.BulletTracer.Rainbow then tracerHue=(tracerHue+0.05)%1 end
    local line=Instance.new("Frame") line.BackgroundColor3=col line.BorderSizePixel=0 line.AnchorPoint=Vector2.new(0,0.5) line.ZIndex=20 line.Size=UDim2.new(0,length,0,S.Misc.BulletTracer.Thickness) line.Position=UDim2.new(0,sFrom.X,0,sFrom.Y) line.Rotation=math.deg(math.atan2(delta.Y,delta.X)) line.Parent=TracerGui
    table.insert(activeTracers,{Line=line,Born=tick(),HitPos=hitPos})
end
RS.RenderStepped:Connect(function()
    local now=tick() local life=S.Misc.BulletTracer.Duration local keep={}
    for _,t in ipairs(activeTracers) do local age=now-t.Born
        if age<life and t.Line and t.Line.Parent then
            local sp,on=Camera:WorldToViewportPoint(t.HitPos) if on and sp.Z>0 then
                local sFrom=getOrigin() local sTo=Vector2.new(sp.X,sp.Y) local delta=sTo-sFrom local len=delta.Magnitude
                t.Line.Size=UDim2.new(0,len,0,S.Misc.BulletTracer.Thickness) t.Line.Position=UDim2.new(0,sFrom.X,0,sFrom.Y) t.Line.Rotation=math.deg(math.atan2(delta.Y,delta.X))
                t.Line.BackgroundColor3=S.Misc.BulletTracer.Rainbow and Color3.fromHSV((tracerHue+age*0.3)%1,1,1) or S.Misc.BulletTracer.Color
                t.Line.BackgroundTransparency=S.Misc.BulletTracer.Fade and math.clamp(age/life,0,0.95) or 0
                t.Line.Visible=true
            else t.Line.Visible=false end
            table.insert(keep,t)
        else pcall(function() if t.Line then t.Line:Destroy() end end) end
    end activeTracers=keep
end)
UIS.InputBegan:Connect(function(i,g) if g then return end if i.UserInputType==Enum.UserInputType.MouseButton1 then fireTracer() end end)

-- ГўвЂўВђГўвЂўВђ HEALTH HOOKS (hit marker, hit notify, kill notify, kill say) ГўвЂўВђГўвЂўВђ
local Library=nil -- declared here, assigned in UI section
local hmConns={}
local function hookPlayer(player)
    if player==LP then return end
    local function connectChar(char)
        local hum=char:FindFirstChild("Humanoid") if not hum then return end
        local head=char:FindFirstChild("Head") if not head then return end
        local lastHP=hum.Health
        if hmConns[player] then pcall(function() hmConns[player]:Disconnect() end) end
        hmConns[player]=hum.HealthChanged:Connect(function(newHP)
            local dmg=lastHP-newHP
            if dmg>0.5 then
                if S.Misc.HitMarker.Enabled then task.spawn(spawnMarker,head,dmg) end
                if S.Misc.HitSound.Enabled then task.spawn(playSound,S.Misc.HitSound.Sound) end
                if S.Misc.HitNotify.Enabled and Library then
                    Library:Notify(S.Misc.HitNotify.Text:gsub("{name}",player.DisplayName):gsub("{dmg}",math.floor(dmg)):gsub("{hp}",math.floor(hum.Health)):gsub("{maxhp}",math.floor(hum.MaxHealth)), S.Misc.HitNotify.Duration)
                end
                if newHP<=0 then
                    if S.Misc.KillNotify.Enabled and Library then
                        Library:Notify(S.Misc.KillNotify.Text:gsub("{name}",player.DisplayName), S.Misc.KillNotify.Duration)
                    end
                    if S.Misc.KillSay.Enabled then
                        task.delay(S.Misc.KillSay.Delay,function()
                            local msg=S.Misc.KillSay.Text:gsub("{name}",player.DisplayName)
                            pcall(function() game:GetService("TextChatService").TextChannels.RBXGeneral:SendAsync(msg) end)
                            pcall(function() local rs=game:GetService("ReplicatedStorage") local ce=rs:FindFirstChild("DefaultChatSystemChatEvents",true) if ce then local sm=ce:FindFirstChild("SayMessageRequest") if sm then sm:FireServer(msg,"All") end end end)
                        end)
                    end
                end
            end
            lastHP=newHP
        end)
    end
    if player.Character then task.spawn(function() task.wait(0.3) connectChar(player.Character) end) end
    player.CharacterAdded:Connect(function(c) task.wait(0.3) connectChar(c) end)
end
for _,p in pairs(Players:GetPlayers()) do hookPlayer(p) end
Players.PlayerAdded:Connect(hookPlayer)
