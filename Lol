local espObjects = {}

local SKELETON_CONNECTIONS = {
    {"Head","UpperTorso"},{"UpperTorso","LowerTorso"},
    {"UpperTorso","RightUpperArm"},{"RightUpperArm","RightLowerArm"},{"RightLowerArm","RightHand"},
    {"UpperTorso","LeftUpperArm"},{"LeftUpperArm","LeftLowerArm"},{"LeftLowerArm","LeftHand"},
    {"LowerTorso","RightUpperLeg"},{"RightUpperLeg","RightLowerLeg"},{"RightLowerLeg","RightFoot"},
    {"LowerTorso","LeftUpperLeg"},{"LeftUpperLeg","LeftLowerLeg"},{"LeftLowerLeg","LeftFoot"},
}

local function createESPObj(player)
    local obj = {}
    pcall(function()
        obj.box      = Drawing.new("Square"); obj.box.Thickness=1.5; obj.box.Filled=false; obj.box.Visible=false
        obj.boxOutline = Drawing.new("Square"); obj.boxOutline.Thickness=3; obj.boxOutline.Filled=false; obj.boxOutline.Visible=false; obj.boxOutline.Color=Color3.fromRGB(0,0,0)
        obj.name     = Drawing.new("Text"); obj.name.Size=13; obj.name.Center=true; obj.name.Outline=true; obj.name.Visible=false
        obj.healthBg = Drawing.new("Square"); obj.healthBg.Filled=true; obj.healthBg.Color=Color3.fromRGB(0,0,0); obj.healthBg.Visible=false
        obj.healthBar= Drawing.new("Square"); obj.healthBar.Filled=true; obj.healthBar.Visible=false
        obj.distance = Drawing.new("Text"); obj.distance.Size=11; obj.distance.Center=true; obj.distance.Outline=true; obj.distance.Visible=false
        obj.tracer   = Drawing.new("Line"); obj.tracer.Thickness=1; obj.tracer.Visible=false
        obj.skeleton = {}
        for _ = 1, #SKELETON_CONNECTIONS do
            local line = Drawing.new("Line"); line.Thickness=1; line.Visible=false; line.Color=Color3.fromRGB(255,255,255)
            table.insert(obj.skeleton, line)
        end
    end)
    espObjects[player] = obj
end

local function removeESPObj(player)
    local obj = espObjects[player]; if not obj then return end
    pcall(function()
        for k, v in pairs(obj) do
            if type(v) == "table" then for _, line in ipairs(v) do pcall(function() line:Remove() end) end
            else pcall(function() v:Remove() end) end
        end
    end)
    espObjects[player] = nil
end

local function hideESPObj(obj)
    pcall(function()
        obj.box.Visible=false; obj.boxOutline.Visible=false; obj.name.Visible=false
        obj.healthBg.Visible=false; obj.healthBar.Visible=false
        obj.distance.Visible=false; obj.tracer.Visible=false
        for _, l in ipairs(obj.skeleton) do l.Visible=false end
    end)
end

local function updateAllESP()
    if not ESP.On then
        for _, obj in pairs(espObjects) do hideESPObj(obj) end; return
    end
    local camPos = camera.CFrame.Position
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LP then continue end
        if not espObjects[player] then createESPObj(player) end
        local obj = espObjects[player]; if not obj or not obj.box then continue end
        local char = player.Character
        if not char then hideESPObj(obj); continue end
        local hum = char:FindFirstChildOfClass("Humanoid")
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local head = char:FindFirstChild("Head")
        if not hum or not hrp or not head or hum.Health<=0 then hideESPObj(obj); continue end
        local dist = (camPos - hrp.Position).Magnitude
        if dist > ESP.MaxDistance then hideESPObj(obj); continue end
        if ESP.TeamCheck and isSameTeamRivals and isSameTeamRivals(player) then hideESPObj(obj); continue end
        local headSP, headVis = camera:WorldToViewportPoint(head.Position + Vector3.new(0,0.7,0))
        local feetSP, feetVis = camera:WorldToViewportPoint(hrp.Position - Vector3.new(0,2.8,0))
        if not headVis and not feetVis then hideESPObj(obj); continue end
        local boxH = math.abs(headSP.Y - feetSP.Y)
        local boxW = boxH * 0.55
        local boxX = headSP.X - boxW/2
        local boxY = headSP.Y
        -- Visibility check for color
        local isVis = false
        pcall(function()
            local p=RaycastParams.new(); p.FilterType=Enum.RaycastFilterType.Exclude; p.FilterDescendantsInstances={LP.Character}
            local r=workspace:Raycast(camPos, hrp.Position-camPos, p)
            isVis = r==nil or r.Instance:IsDescendantOf(char)
        end)
        local boxCol = isVis and ESP.VisibleColor or ESP.BoxColor
        -- Box
        if ESP.Boxes then
            obj.boxOutline.Size=Vector2.new(boxW+2,boxH+2); obj.boxOutline.Position=Vector2.new(boxX-1,boxY-1); obj.boxOutline.Visible=true
            obj.box.Size=Vector2.new(boxW,boxH); obj.box.Position=Vector2.new(boxX,boxY); obj.box.Color=boxCol; obj.box.Visible=true
        else obj.box.Visible=false; obj.boxOutline.Visible=false end
        -- Name
        if ESP.Names then
            obj.name.Text=player.DisplayName; obj.name.Position=Vector2.new(headSP.X,boxY-16)
            obj.name.Color=ESP.NameColor; obj.name.Visible=true
        else obj.name.Visible=false end
        -- Health bar
        if ESP.Health then
            local ratio=hum.Health/hum.MaxHealth; local barH=boxH; local barX=boxX-8; local barY=boxY
            obj.healthBg.Size=Vector2.new(5,barH+2); obj.healthBg.Position=Vector2.new(barX,barY-1); obj.healthBg.Visible=true
            obj.healthBar.Size=Vector2.new(5,barH*ratio); obj.healthBar.Position=Vector2.new(barX,barY+barH*(1-ratio))
            local r=math.clamp(math.floor((1-ratio)*510),0,255); local g=math.clamp(math.floor(ratio*510),0,255)
            obj.healthBar.Color=Color3.fromRGB(r,g,0); obj.healthBar.Visible=true
        else obj.healthBg.Visible=false; obj.healthBar.Visible=false end
        -- Distance
        if ESP.Distance then
            obj.distance.Text=math.floor(dist).." m"; obj.distance.Position=Vector2.new(feetSP.X,feetSP.Y+3)
            obj.distance.Color=ESP.NameColor; obj.distance.Visible=true
        else obj.distance.Visible=false end
        -- Tracer
        if ESP.Tracers then
            local vc=camera.ViewportSize
            obj.tracer.From=Vector2.new(vc.X/2,vc.Y); obj.tracer.To=Vector2.new(feetSP.X,feetSP.Y)
            obj.tracer.Color=ESP.TracerColor; obj.tracer.Thickness=1; obj.tracer.Visible=true
        else obj.tracer.Visible=false end
        -- Skeleton
        if ESP.Skeleton then
            for i, conn in ipairs(SKELETON_CONNECTIONS) do
                local p1=char:FindFirstChild(conn[1]); local p2=char:FindFirstChild(conn[2])
                local line=obj.skeleton[i]
                if p1 and p2 then
                    local sp1,v1=camera:WorldToViewportPoint(p1.Position)
                    local sp2,v2=camera:WorldToViewportPoint(p2.Position)
                    if v1 and v2 then
                        line.From=Vector2.new(sp1.X,sp1.Y); line.To=Vector2.new(sp2.X,sp2.Y)
                        line.Color=boxCol; line.Visible=true
                    else line.Visible=false end
                else line.Visible=false end
            end
        else for _, l in ipairs(obj.skeleton) do l.Visible=false end end
    end
end

