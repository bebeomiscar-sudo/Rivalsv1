local function sa_calcPoint(origin,target_pos,target_char)
    ray_params_sa.FilterDescendantsInstances={LP.Character,target_char}; ray_params_sa.FilterType=Enum.RaycastFilterType.Exclude
    if not silentVisibleCheck then return origin,nil end
    if not ws_sa:Raycast(origin,target_pos-origin,ray_params_sa) then return origin,nil end
    for _,offset in next,sa_offsets do
        local sp=origin+offset
        if not ws_sa:Raycast(sp,target_pos-sp,ray_params_sa) then return sp,offset.Y end
    end
    return nil,nil
