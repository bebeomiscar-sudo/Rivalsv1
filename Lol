local watermark=library:Hud()

table.insert(ActiveConnections,RunService.RenderStepped:Connect(function(dt)
    camera=workspace.CurrentCamera; local center=getScreenCenter()

    -- Crosshair
    if CFG.Crosshair.On then chImg.Position=UDim2.new(0.5,0,0.5,0) end

    -- FOV circles
    if fovCircle then fovCircle.Position=center; fovCircle.Radius=AimbotCFG.MaxFOV; fovCircle.Visible=AimbotCFG.DrawFOV and AimbotCFG.On end
    if saFovCircle then saFovCircle.Position=center; saFovCircle.Radius=SAHookCFG.IgnoreFOV and 0 or saGetEffectiveFOV(); saFovCircle.Visible=SAHookCFG.DrawFOV and SAHookCFG.On and not SAHookCFG.IgnoreFOV end

    -- ESP
    updateAllESP()

    -- Chams (applied every frame to handle weapon switches)
    if ChamCFG.ArmOn or ChamCFG.WeaponOn then applyChams() end

    -- ═══ AIMBOT (STICKY LOCK) ═══
    if AimbotCFG.On and CameraController then
        if isInReaction then reactionTimer=reactionTimer-dt; if reactionTimer<=0 then isInReaction=false end end
        if not isInReaction then
            if lockedTarget and not isTargetStillValid(lockedTarget) then lockedTarget=nil; lockTimer=0 end
            if not lockedTarget then
                local newT=findNewAimbotTarget()
                if newT then lockedTarget=newT; lockTimer=0; isInReaction=true; reactionTimer=AimbotCFG.ReactionTime/1000 end
            end
            if lockedTarget then
                lockTimer=lockTimer+dt
                if lockTimer>AimbotCFG.MaxLockTime then lockedTarget=nil; lockTimer=0
                else
                    local isAtk=false; pcall(function() if fighter_mod and fighter_mod.LocalFighter then isAtk=fighter_mod.LocalFighter:Get("IsShooting")==true end end)
                    local speed=isAtk and AimbotCFG.SpeedInAttack or AimbotCFG.Speed
                    local sp2,on2=camera:WorldToScreenPoint(lockedTarget.Position)
                    if on2 then local sd=(Vector2.new(sp2.X,sp2.Y)-center).Magnitude; local fr=getEffectiveFOV(); if fr>0 then speed=speed*math.max(0.1,1-(sd/fr)*(AimbotCFG.SpeedScaleFOV/100)) end end
                    pcall(function()
                        local cp=camera.CFrame.Position; local du=(lockedTarget.Position-cp).Unit
                        local tP=math.asin(du.Y); local tY=math.atan2(-du.X,-du.Z); local sm=math.clamp(speed/5,0,1); local cur=CameraController.Rotation
                        CameraController:SetRotation(Vector2.new(cur.X+(tP-cur.X)*sm,cur.Y+angleDiff(cur.Y,tY)*sm))
                    end)
                end
            end
        end
    end

    -- ═══ TRIGGERBOT (FIXED — grace fires shots) ═══
    if TrigCFG.On then
        local tgt=getTriggerTarget()
        if tgt then
            -- Target on crosshair — reset grace, setup shooting
            TrigState.grace=TrigCFG.Grace/1000
            if not TrigState.waiting then
                TrigState.waiting=true; TrigState.timer=getTrigDelay(); TrigState.cooldown=0; TrigState.shooting=false
            end
            TrigState.timer=TrigState.timer-dt
            if TrigState.timer<=0 then TrigState.shooting=true end
            if TrigState.shooting then
                TrigState.cooldown=TrigState.cooldown-dt
                if TrigState.cooldown<=0 then simClick(); TrigState.cooldown=TrigCFG.BurstMs/1000 end
            end
        else
            -- No target — grace period keeps shooting
            if TrigState.waiting then
                TrigState.grace=TrigState.grace-dt
                if TrigState.grace>0 then
                    if TrigState.shooting then
                        TrigState.cooldown=TrigState.cooldown-dt
                        if TrigState.cooldown<=0 then simClick(); TrigState.cooldown=TrigCFG.BurstMs/1000 end
                    end
                else
                    TrigState.waiting=false; TrigState.timer=0; TrigState.grace=0; TrigState.cooldown=0; TrigState.shooting=false
                end
            end
        end
    else
        TrigState.waiting=false; TrigState.timer=0; TrigState.grace=0; TrigState.cooldown=0; TrigState.shooting=false
    end

    -- ═══ MOBILE TRIGGERBOT ═══
    if IsMobile and MobileTrigCFG.On then
        local sf=MobileTrigCFG.AutoFire or (MobileTrigCFG.HoldToShoot and MobileTrigState.touching)
        if sf then
            local tgt=getMobileTrigTarget()
            if tgt then
                if not MobileTrigState.waiting then MobileTrigState.waiting=true; MobileTrigState.timer=MobileTrigCFG.Delay/1000; MobileTrigState.cooldown=0 end
                MobileTrigState.timer=MobileTrigState.timer-dt
                if MobileTrigState.timer<=0 then MobileTrigState.cooldown=MobileTrigState.cooldown-dt; if MobileTrigState.cooldown<=0 then simClick(); MobileTrigState.cooldown=MobileTrigCFG.BurstMs/1000 end end
            else
                if not MobileTrigState.touching then MobileTrigState.waiting=false; MobileTrigState.timer=0; MobileTrigState.cooldown=0 end
            end
        else MobileTrigState.waiting=false; MobileTrigState.timer=0; MobileTrigState.cooldown=0 end
    end

    -- ═══ WATERMARK ═══
    local parts={"Rivals Tool v9.8"}
    if WatermarkCFG.ShowTime then table.insert(parts,os.date("%H:%M:%S")) end
    if WatermarkCFG.ShowActive then
        local a={}
        if AimbotCFG.On then table.insert(a,"AIM") end
        if SAHookCFG.On then table.insert(a,"HOOK") end
        if silentActive then table.insert(a,"RAGE") end
        if TrigCFG.On then table.insert(a,"TRIG") end
        if IsMobile and MobileTrigCFG.On then table.insert(a,"MTRIG") end
        if CFG.Void.On then table.insert(a,"VOID") end
        if CFG.Orbit.On then table.insert(a,"ORBIT") end
        if ESP.On then table.insert(a,"ESP") end
        if QMConfig.AutoOn then table.insert(a,"QM") end
        if OOBConfig.AutoOn then table.insert(a,"OOB") end
        if GunCFG.NoRecoil or GunCFG.NoSpread or GunCFG.FastShoot then table.insert(a,"GUN") end
        if #a>0 then table.insert(parts,"["..table.concat(a," ").."]") end
    end
    watermark:SetText(table.concat(parts," | "))
end))

