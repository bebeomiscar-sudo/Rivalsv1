local function applyViewmodelSkin(wt,sn)
    local found=nil; for _,v in ipairs(al:GetDescendants()) do if v.Name==wt then found=v; break end end
    if not found then return end
    if sn and sn~="Default" then
        local sm=nil; for _,v in ipairs(al:GetDescendants()) do if v.Name==sn then sm=v; break end end
        if sm then found:ClearAllChildren(); for _,item in ipairs(sm:GetChildren()) do item:Clone().Parent=found end; skinConfig.ActiveSkins[wt]=sn end
    else skinConfig.ActiveSkins[wt]=nil end
end

local function applyMaterial()
    if not skinConfig.MaterialEnabled then return end
    local id=ReplicatedStorage.Assets.Temp.ViewModels
    for _,ih in ipairs(id:GetChildren()) do
        if string.find(ih.Name,LP.Name.." -",1,true)==1 then
            local ig=ih:FindFirstChild("ItemVisual")
            if ig then for _,v in ipairs(ig:GetDescendants()) do if v:IsA("BasePart") or v:IsA("MeshPart") then pcall(function() v.Material=Enum.Material[skinConfig.CurrentMaterial] end); v.Transparency=skinConfig.Transparency/100 end end end
        end
    end
end

