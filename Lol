    if not skin or skin=="" then return end
    local al=SC_GetVMs() if not al then return end
    local wm=nil for _,v in ipairs(al:GetDescendants()) do if v.Name==weapon then wm=v break end end
    if not wm then return end
    if not SC_Backups:FindFirstChild(weapon) then
        local bk=Instance.new("Folder") bk.Name=weapon
        for _,i in ipairs(wm:GetChildren()) do local c=i:Clone() if c then c.Parent=bk end end
        bk.Parent=SC_Backups
    end
    local sm=nil for _,v in ipairs(al:GetDescendants()) do if v.Name==skin then sm=v break end end
    if not sm then return end
    wm:ClearAllChildren()
    for _,i in ipairs(sm:GetChildren()) do i:Clone().Parent=wm end
    pcall(function() local w=workspace:FindFirstChild(weapon) if w then w:ClearAllChildren() for _,i in ipairs(sm:GetChildren()) do i:Clone().Parent=w end end end)
end
local function SC_Reset(tool)
    if not tool then return end
    local bk=SC_Backups:FindFirstChild(tool.Name) if not bk then return end
    local al=SC_GetVMs() if not al then return end
    local wm=nil for _,v in ipairs(al:GetDescendants()) do if v.Name==tool.Name then wm=v break end end
    if not wm then return end
    wm:ClearAllChildren() for _,i in ipairs(bk:GetChildren()) do i:Clone().Parent=wm end
end
