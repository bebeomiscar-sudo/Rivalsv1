local function getHRP(p) local c=p.Character return c and c:FindFirstChild("HumanoidRootPart") end
local function getHum(p) local c=p.Character return c and c:FindFirstChildOfClass("Humanoid") end

local function isVisible(from, target)
    local rp=RaycastParams.new()
    rp.FilterDescendantsInstances={LP.Character}
    rp.FilterType=Enum.RaycastFilterType.Exclude
    local res=workspace:Raycast(from,(target-from),rp)
    return not res or res.Instance:IsDescendantOf(target.Parent)
end

local function isSameTeam(p)
    return pcall(function() return LP.Team and p.Team and LP.Team==p.Team end) and LP.Team==p.Team
end

-- ══ TARGET SELECTION ══
local function getClosest(opts)
    opts = opts or {}
    local teamCheck = opts.teamCheck or false
    local visCheck  = opts.visCheck  or false
    local radius    = opts.radius    or math.huge
    local closest, closestD = nil, math.huge
    local localHRP = getHRP(LP)
    if not localHRP then return nil end
    for _,p in pairs(Players:GetPlayers()) do
        if p==LP then continue end
        if teamCheck and isSameTeam(p) then continue end
        local hrp=getHRP(p) if not hrp then continue end
        local hum=getHum(p) if not hum or hum.Health<=0 then continue end
        local d=(hrp.Position-localHRP.Position).Magnitude
        if d>radius then continue end
        if visCheck and not isVisible(Camera.CFrame.Position, hrp.Position) then continue end
        if d<closestD then closestD=d closest=p end
    end
    return closest
end

