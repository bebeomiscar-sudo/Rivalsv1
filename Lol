-- ═══════════════════════════════════════════
-- SA HOOK (FIXED VISIBLE CHECK)
-- ═══════════════════════════════════════════
local saHookTarget=nil; local saHookConn=nil; local saHookApplied=false; local saHookIdx=nil

local function saHookByte(a) return string.byte(a or "\0") end

local function saGetEffectiveFOV()
    if SAHookCFG.IgnoreFOV then return math.huge end
    local f=SAHookCFG.FOVSize
    if SAHookCFG.DynamicFOV then f=f*(camera.FieldOfView/70) end
    return f
end

local SA_PART_MAP = {
    ["Head"]={"Head"},["Body"]={"UpperTorso","LowerTorso","HumanoidRootPart"},
    ["Head, Body"]={"Head","UpperTorso","LowerTorso","HumanoidRootPart"},
    ["Body, Head"]={"UpperTorso","LowerTorso","Head"},
}

local function saGetTargetPart(char)
    local names=SA_PART_MAP[SAHookCFG.TargetParts] or {"Head"}
    if SAHookCFG.PreferRandom then
        local v={}
        for _,n in ipairs(names) do local p=char:FindFirstChild(n); if p then table.insert(v,p) end end
        if #v>0 then return v[math.random(1,#v)] end
        return nil
    end
    for _,n in ipairs(names) do local p=char:FindFirstChild(n); if p then return p end end
    return nil
end

-- FIXED: use actual vector to target (not unit * distance which can overshoot)
local function saHookVisible(part, camPos)
    if not SAHookCFG.VisCheck then return true end
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.FilterDescendantsInstances = {LP.Character, part.Parent, workspace:FindFirstChild("Debris")}
    -- Use the actual direction vector — stops at the target position, no overshoot
    local direction = part.Position - camPos
    local result = workspace:Raycast(camPos, direction, params)
    -- If nothing was hit OR the thing hit is part of target's character = visible
    return result == nil or result.Instance:IsDescendantOf(part.Parent)
end

local function saHookValid(plr, camPos, center)
    local char=plr.Character; if not char then return false end
    local hum=char:FindFirstChildOfClass("Humanoid")
    if not (hum and hum.Health>0) then return false end
    local myEnv=LP:GetAttribute("EnvironmentID"); local theirEnv=plr:GetAttribute("EnvironmentID")
    if myEnv and theirEnv and saHookByte(myEnv)~=saHookByte(theirEnv) then return false end
    if SAHookCFG.TeamCheck then
        local mt=LP:GetAttribute("TeamID"); local tt=plr:GetAttribute("TeamID")
        if mt and tt and saHookByte(mt)==saHookByte(tt) then return false end
    end
    local head=char:FindFirstChild("Head"); if not head then return false end
    if (head.Position-camPos).Magnitude>SAHookCFG.Distance then return false end
    if not SAHookCFG.IgnoreFOV then
        local sp,on=workspace.CurrentCamera:WorldToViewportPoint(head.Position)
        if not on then return false end
        if (Vector2.new(sp.X,sp.Y)-center).Magnitude>saGetEffectiveFOV() then return false end
    end
    local tp=saGetTargetPart(char); if not tp then return false end
    -- FIXED: pass the target part for correct visibility check
    if not saHookVisible(tp, camPos) then return false end
    return true
end

local function startSAHook()
    if not saHookApplied then
        local ok=pcall(function()
            saHookIdx=hookmetamethod(game,"__index",newcclosure(function(self,idx,...)
                if saHookTarget and not checkcaller() and idx=="ViewportSize" and self==workspace.CurrentCamera then
